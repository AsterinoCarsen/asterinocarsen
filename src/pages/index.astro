---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Carsen Asterino</title>
        <meta
            name="description"
            content="Software engineer building modern, performant, and thoughtfully designed digital experiences."
        />
    </head>

    <body class="bg-neutral-950 text-neutral-100 antialiased selection:bg-neutral-800">
        <!-- HERO -->
        <section class="relative overflow-hidden">
            <div class="max-w-6xl mx-auto px-6 py-28 grid gap-16 md:grid-cols-2 items-center">
                <div>
                    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight">Hi, I’m Carsen.</h1>

                    <p class="mt-6 text-xl text-neutral-300 max-w-xl">
                        Software engineering student focused on building modern, performant
                        applications with clean design and thoughtful implementation.
                    </p>

                    <p class="mt-4 text-neutral-400 max-w-xl">
                        I enjoy working across the stack, collaborating in structured teams, and
                        turning complex requirements into clear, maintainable solutions.
                    </p>

                    <div class="mt-10 flex flex-wrap gap-4">
                        <a
                            href="#work"
                            class="inline-flex items-center rounded-md bg-white text-neutral-950 px-6 py-3 text-sm font-semibold hover:bg-neutral-200 transition"
                        >
                            Selected work
                        </a>
                        <a
                            href="#about"
                            class="inline-flex items-center rounded-md border border-neutral-700 px-6 py-3 text-sm font-semibold hover:border-neutral-500 transition"
                        >
                            About
                        </a>
                    </div>
                </div>

                <!-- Image placeholder -->
                <div class="relative">
                    <div
                        class="aspect-square rounded-2xl border border-neutral-800 bg-neutral-900
                    flex items-center justify-center text-neutral-500 text-sm"
                    >
                        Your photo
                    </div>
                </div>
            </div>
        </section>

        <!-- VALUE / PHILOSOPHY -->
        <section class="bg-neutral-900">
            <div class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-3 gap-10">
                <div>
                    <h3 class="text-lg font-semibold">Thoughtful design</h3>
                    <p class="mt-2 text-neutral-400 text-sm">
                        Clean visual hierarchy, intentional spacing, and interfaces that prioritize
                        clarity over noise.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-semibold">Solid engineering</h3>
                    <p class="mt-2 text-neutral-400 text-sm">
                        Maintainable codebases, modern tooling, and an understanding of tradeoffs
                        across the stack.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-semibold">Performance-aware</h3>
                    <p class="mt-2 text-neutral-400 text-sm">
                        Fast load times, responsive layouts, and systems that scale gracefully.
                    </p>
                </div>
            </div>
        </section>

        <!-- WORK -->
        <section id="work" class="bg-neutral-950">
            <div class="max-w-6xl mx-auto px-6 py-28">
                <h2 class="text-3xl font-bold">Selected work</h2>
                <p class="mt-4 text-neutral-400 max-w-xl">
                    A small collection of projects highlighting technical depth, design sensibility,
                    and real-world constraints.
                </p>

                <div class="mt-14 grid gap-8 md:grid-cols-2">
                    <article
                        class="group relative rounded-xl border border-neutral-800 bg-neutral-900 p-8 transition
                   hover:-translate-y-1 hover:border-neutral-600 hover:shadow-2xl hover:shadow-black/40"
                    >
                        <h3 class="text-xl font-semibold">Climbing Performance Analytics</h3>

                        <p class="mt-3 text-neutral-400">
                            Full-stack analytics platform focused on data visualization,
                            performance, and user experience.
                        </p>

                        <ul class="mt-4 text-sm text-neutral-500 space-y-1">
                            <li>Next.js · Node.js · PostgreSQL</li>
                            <li>Custom REST APIs · Auth · Responsive UI</li>
                            <li>Lighthouse performance score: 99/100</li>
                        </ul>

                        <a
                            href="https://github.com/AsterinoCarsen"
                            class="inline-flex items-center mt-6 text-sm font-medium text-white group-hover:underline"
                        >
                            View project →
                        </a>
                    </article>

                    <article
                        class="group relative rounded-xl border border-neutral-800 bg-neutral-900 p-8 transition
                   hover:-translate-y-1 hover:border-neutral-600 hover:shadow-2xl hover:shadow-black/40"
                    >
                        <h3 class="text-xl font-semibold">Real Estate Mobile Application</h3>

                        <p class="mt-3 text-neutral-400">
                            Sponsor-backed mobile application developed in a collaborative,
                            sprint-based academic capstone environment.
                        </p>

                        <ul class="mt-4 text-sm text-neutral-500 space-y-1">
                            <li>Expo · iOS & Android</li>
                            <li>Agile team of 5 · Sponsor-facing reviews</li>
                            <li>Continuous integration and PR workflows</li>
                        </ul>
                    </article>
                </div>
            </div>
        </section>

        <!-- ABOUT -->
        <section id="about" class="bg-neutral-900">
            <div class="max-w-6xl mx-auto px-6 py-28">
                <h2 class="text-3xl font-bold">About</h2>

                <p class="mt-6 text-neutral-400 max-w-3xl leading-relaxed">
                    I’m a senior software engineering student at Arizona State University with
                    experience building full-stack web applications, mobile apps, and working within
                    structured development teams. I care deeply about writing clear, maintainable
                    code and creating interfaces that feel intentional and well-considered.
                </p>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="border-t border-neutral-800 py-12 text-center text-sm text-neutral-500">
            <div class="flex justify-center gap-6">
                <a
                    href="https://github.com/AsterinoCarsen"
                    class="hover:text-neutral-300 transition"
                >
                    GitHub
                </a>
                <a
                    href="https://www.linkedin.com/in/carsen-asterino"
                    class="hover:text-neutral-300 transition"
                >
                    LinkedIn
                </a>
                <a href="mailto:casteri1@asu.edu" class="hover:text-neutral-300 transition">
                    Email
                </a>
            </div>

            <p class="mt-6">
                © {new Date().getFullYear()} Carsen Asterino
            </p>
        </footer>
    </body>
</html>
