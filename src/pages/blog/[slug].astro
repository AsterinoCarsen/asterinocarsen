---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Analytics from "@vercel/analytics/astro";
import me from "../../assets/me.webp";
import "../../styles/global.css";

export async function getStaticPaths() {
    const posts = await getCollection("blog");

    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const siteURL = "https://asterino.dev";
const postURL = `${siteURL}/blog/${post.slug}`;
const ogImage = post.data.imgURL
    ? (post.data.imgURL.startsWith("http") ? post.data.imgURL : `${siteURL}${post.data.imgURL}`)
    : `${siteURL}/og-default.png`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>{post.data.title} | Carsen Asterino</title>
        <meta name="description" content={post.data.description} />
        <link rel="canonical" href={postURL} />
        <link rel="icon" href="/favicon.png" sizes="any" />

        <meta property="og:type" content="article" />
        <meta property="og:url" content={postURL} />
        <meta property="og:title" content={post.data.title} />
        <meta property="og:description" content={post.data.description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="Carsen Asterino" />
        <meta property="article:published_time" content={post.data.pubDate.toISOString()} />
        <meta property="article:author" content="Carsen Asterino" />
    </head>

    <body class="bg-neutral-950 text-neutral-100 antialiased selection:bg-neutral-800">
        <header class="border-b border-neutral-800 bg-neutral-950/90 backdrop-blur">
            <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-5 sm:px-6">
                <a
                    href="/"
                    class="inline-flex items-center rounded-md border border-neutral-700 px-4 py-2 text-sm font-semibold hover:border-neutral-500 transition"
                >
                    Back home
                </a>
            </div>
        </header>

        <main class="mx-auto max-w-4xl overflow-x-hidden px-4 py-10 sm:px-6 sm:py-16">
            <article class="rounded-2xl border border-neutral-800 bg-neutral-900 p-5 sm:p-8 md:p-12">
                <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-5xl">
                    {post.data.title}
                </h1>
                <p class="mt-4 text-neutral-300">{post.data.description}</p>
                {
                    post.data.imgURL && (
                        <Image
                            src={post.data.imgURL}
                            alt={post.data.title}
                            inferSize
                            class="mt-6 w-full rounded-lg object-cover select-none"
                            draggable="false"
                        />
                    )
                }

                <div class="flex items-center pt-6 gap-4">
                    <Image
                        src={me}
                        alt="Carsen Asterino"
                        class="h-12 w-12 rounded-full object-cover ring-1 ring-neutral-700 transition hover:ring-neutral-500"
                    />
                    <span class="text-base text-neutral-300 transition hover:text-white">
                        Carsen Asterino
                    </span>
                </div>
                <p class="text-sm text-neutral-400 pt-4">{post.data.pubDate.toDateString()}</p>

                <div
                    class="mt-10 border-t border-neutral-800 pt-8 leading-8 text-neutral-200 [&_h1]:text-3xl [&_h1]:font-bold [&_h1]:mt-10 [&_h1]:mb-4 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:mt-8 [&_h2]:mb-3 [&_p]:mb-5 [&_a]:underline [&_a]:text-white [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-5 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-5 [&_li]:mb-2 [&_hr]:border-neutral-700 [&_blockquote]:border-l-2 [&_blockquote]:border-neutral-500 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-neutral-400 [&_blockquote]:my-6"
                >
                    <Content />
                </div>
            </article>
        </main>

        <footer class="border-t border-neutral-800 py-10 text-center text-sm text-neutral-500">
            <p>Copyright {new Date().getFullYear()} Carsen Asterino</p>
        </footer>

        <Analytics />
    </body>
</html>
