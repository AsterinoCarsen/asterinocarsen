---
interface Props {
    href: string;
    title: string;
    description?: string;
    meta?: string;
    readingMinutes?: number;
    class?: string;
    ariaLabel?: string;
}

const {
    href,
    title,
    description,
    meta,
    readingMinutes,
    class: className = "",
    ariaLabel,
} = Astro.props as Props;

const readingTime = readingMinutes ? `${readingMinutes} min read` : undefined;
---

<a
    href={href}
    target="_blank"
    aria-label={ariaLabel ?? title}
    class:list={[
        "group relative block overflow-hidden rounded-xl px-4 py-6 transition-colors hover:bg-white/2 sm:px-6 sm:py-7",
        className,
    ]}
>
    <div class="min-w-0 pr-8 sm:pr-10">
        <h2 class="text-xl font-bold leading-tight text-white sm:text-2xl">{title}</h2>
    </div>

    <svg
        xmlns="http://www.w3.org/2000/svg"
        focusable="false"
        viewBox="0 0 24 24"
        color="var(--token-733bbd01-4431-42a0-b8b0-48fb9de5f3db, rgb(244, 108, 56))"
        class="absolute right-6 top-7 h-5 w-5"
        style="user-select: none; fill: var(--token-733bbd01-4431-42a0-b8b0-48fb9de5f3db, rgb(244, 108, 56)); flex-shrink: 0; transform: rotate(-45deg);"
    >
        <path d="M15 5l-1.41 1.41L18.17 11H2v2h16.17l-4.59 4.59L15 19l7-7-7-7z" />
    </svg>

    {description && <p class="mt-4 max-w-2xl whitespace-pre-line leading-[1.35] text-white/60">{description}</p>}

    {
        (meta || readingTime) && (
            <div class="mt-8 flex flex-wrap items-center gap-2 text-sm text-white/55">
                {meta && <span>{meta}</span>}
                {meta && readingTime && <span class="text-white/25" aria-hidden="true">/</span>}
                {readingTime && (
                    <span class="font-medium text-white/75">
                        {readingTime}
                    </span>
                )}
            </div>
        )
    }
</a>

