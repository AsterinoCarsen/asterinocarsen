---
interface Props {
    name: string;
    source: string;
    title?: string;
    text: string;
    href?: string;
}

const { name, source, title, text, href } = Astro.props as Props;
---

<div class="group relative block overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.03] px-4 py-6 transition-colors hover:bg-white/[0.06] sm:px-6 sm:py-7">
    <svg
        class="mb-4 h-6 w-6 text-[#f46c38] opacity-80"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
    >
        <path d="M11.192 15.757c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.956.76-3.022.66-1.065 1.515-1.867 2.558-2.403L9.373 5c-.8.396-1.56.898-2.26 1.505-.71.607-1.34 1.305-1.9 2.094s-.98 1.68-1.25 2.69-.346 2.04-.217 3.1c.168 1.4.62 2.52 1.356 3.35.735.84 1.652 1.26 2.748 1.26.965 0 1.766-.29 2.4-.878.628-.576.94-1.365.94-2.368l.002.003zm9.124 0c0-.88-.23-1.618-.69-2.217-.326-.42-.77-.692-1.327-.817-.56-.124-1.074-.13-1.54-.022-.16-.94.09-1.95.75-3.02.66-1.06 1.514-1.86 2.557-2.4L18.49 5c-.8.396-1.555.898-2.26 1.505-.708.607-1.34 1.305-1.894 2.094-.556.79-.97 1.68-1.24 2.69-.273 1-.346 2.04-.217 3.1.166 1.4.62 2.52 1.356 3.35.735.84 1.652 1.26 2.748 1.26.965 0 1.766-.29 2.4-.878.628-.576.94-1.365.94-2.368l.002.003z" />
    </svg>

    <p class="max-w-2xl leading-[1.35] text-white/60">{text}</p>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="min-w-0">
            <p class="font-bold text-white">{name}</p>
            {title && <p class="text-sm text-white/40">{title}</p>}
        </div>

        {href ? (
            <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-white/40 transition-colors hover:text-[#f46c38]"
                aria-label={`View ${name} on ${source}`}
            >
                {source}
            </a>
        ) : (
            <span class="text-sm text-white/40">{source}</span>
        )}
    </div>
</div>
