---
import "../styles/global.css";
import Navbar from "./Navbar.astro";
import Profile from "./Profile.astro";
import Analytics from "@vercel/analytics/astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Carsen Asterino</title>
        <meta name="description" content="Software Engineer major at Arizona State University." />
        <link rel="canonical" href="https://asterino.dev" />
        <link rel="icon" href="/favicon.png" sizes="any" />

        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://asterino.dev" />
        <meta property="og:title" content="Carsen Asterino" />
        <meta property="og:description" content="Software Engineer major at Arizona State University." />
        <meta property="og:image" content="https://asterino.dev/og-default.png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="Carsen Asterino" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content="https://asterino.dev" />
        <meta name="twitter:title" content="Carsen Asterino" />
        <meta name="twitter:description" content="Software Engineer major at Arizona State University." />
        <meta name="twitter:image" content="https://asterino.dev/og-default.png" />
    </head>

    <body class="min-h-screen bg-black text-white antialiased">
        <main
            class="mx-auto flex min-h-screen w-full max-w-7xl flex-col overflow-x-hidden px-4 py-8 sm:px-6 md:px-10 md:py-12"
        >
            <div class="flex w-full justify-center">
                <Navbar />
            </div>

            <div
                class="mt-6 grid min-w-0 flex-1 gap-8 lg:grid-cols-[minmax(260px,340px)_1fr] lg:items-start"
            >
                <aside class="w-full lg:sticky lg:top-8 lg:self-start">
                    <Profile />
                </aside>

                <section class="slot-content min-w-0 w-full [&>*+*]:mt-26 md:[&>*+*]:mt-32">
                    <slot />
                </section>
            </div>

            <hr class="my-8 border-white/20" />
            <p class="mt-8 text-sm text-white/70">
                Made by Carsen Asterino | Powered by
                <a target="_blank" rel="noopener noreferrer" href="https://astro.build/">Astro</a> and
                <a target="_blank" rel="noopener noreferrer" href="https://tailwindcss.com/"
                    >Tailwind CSS</a
                > |
                <a
                    target="_blank"
                    rel="noopener noreferrer"
                    href="https://github.com/AsterinoCarsen/asterinocarsen">Source Code</a
                >
            </p>
        </main>

        <Analytics />

        {/* Reveal on scroll */}
        <script is:inline>
            const container = document.querySelector(".slot-content");
            if (container) {
                const items = [...container.children];
                const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

                items.forEach((el) => el.classList.add("reveal"));

                if (reduced) {
                    items.forEach((el) => el.classList.add("is-visible"));
                } else {
                    const observer = new IntersectionObserver(
                        (entries, obs) => {
                            entries.forEach((entry) => {
                                if (entry.isIntersecting) {
                                    entry.target.classList.add("is-visible");
                                    obs.unobserve(entry.target);
                                }
                            });
                        },
                        { threshold: 0.1, rootMargin: "0px 0px -10% 0px" },
                    );

                    items.forEach((el) => observer.observe(el));
                }
            }
        </script>
    </body>
</html>
