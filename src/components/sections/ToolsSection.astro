---
import ToolCard from "../cards/ToolCard.astro";
---

<section>
    <h1 class="text-[clamp(2.75rem,13vw,6rem)] font-extrabold leading-none lg:text-8xl">POWERFUL</h1>
    <h1 class="text-[clamp(2.75rem,13vw,6rem)] font-extrabold leading-none text-white/20 lg:text-8xl">TOOLS</h1>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-8 lg:gap-14">
        <ToolCard
            href="https://react.dev/"
            title="React"
            subtitle="Frontend development"
            logo="/icons/reactjs.svg"
        />

        <ToolCard
            href="https://nextjs.org/"
            title="Next.js"
            subtitle="React-based web framework"
            logo="/icons/nextjs.svg"
        />

        <ToolCard
            href="https://expo.dev/"
            title="Expo"
            subtitle="Mobile development"
            logo="/icons/expo.svg"
        />

        <ToolCard
            href="https://spring.io/"
            title="Spring Boot"
            subtitle="Backend development"
            logo="/icons/spring.svg"
        />

        <ToolCard
            href="https://dotnet.microsoft.com/en-us/apps/aspnet"
            title="ASP.NET"
            subtitle="Web development"
            logo="/icons/dotnet.svg"
        />

        <ToolCard
            href="https://aws.amazon.com/"
            title="AWS"
            subtitle="Cloud computing platform"
            logo="/icons/aws.svg"
        />
    </div>
</section>
