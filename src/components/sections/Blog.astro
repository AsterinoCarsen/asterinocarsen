---
import { getCollection } from "astro:content";
import PreviewCard from "../PreviewCard.astro";

const latestPosts = (await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);
---

<section>
    <h1 class="text-8xl font-extrabold">DESIGN</h1>
    <h1 class="text-8xl font-extrabold text-white/20">THOUGHTS</h1>

    <div class="mt-10 space-y-4">
        {
            latestPosts.map((post) => (
                <PreviewCard
                    href={`/blog/${post.slug}/`}
                    title={post.data.title}
                    description={post.data.description}
                    meta={post.data.pubDate.toDateString()}
                />
            ))
        }
    </div>
</section>

