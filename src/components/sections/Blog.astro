---
import { getCollection } from "astro:content";

const latestPosts = (await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);
---

<section>
    <h1 class="text-8xl font-extrabold">DESIGN</h1>
    <h1 class="text-8xl font-extrabold text-white/20">THOUGHTS</h1>

    <div class="mt-10">
        {
            latestPosts.map((post) => (
                <a
                    href={`/blog/${post.slug}/`}
                    class="group p-6 transition-colors hover:border-gray-400"
                >
                    <div class="flex">
                        <h2 class="text-2xl font-bold group-hover:text-gray-700">
                            {post.data.title}
                        </h2>

                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            focusable="false"
                            viewBox="0 0 24 24"
                            color="var(--token-733bbd01-4431-42a0-b8b0-48fb9de5f3db, rgb(244, 108, 56))"
                            style="user-select: none; width: 24px; height: 24px; display: inline-block; fill: var(--token-733bbd01-4431-42a0-b8b0-48fb9de5f3db, rgb(244, 108, 56)); flex-shrink: 0;"
                        >
                            <path d="M15 5l-1.41 1.41L18.17 11H2v2h16.17l-4.59 4.59L15 19l7-7-7-7z" />
                        </svg>
                    </div>

                    <p class="mt-2 text-sm text-gray-600">{post.data.description}</p>

                    <p class="mt-2 text-sm text-gray-600">{post.data.pubDate.toDateString()}</p>
                </a>
            ))
        }
    </div>
</section>

